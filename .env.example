# ──────────────────────────────────────────────────────────────────────────
# DevHub Frontend — environment variables
# ──────────────────────────────────────────────────────────────────────────
# Copy this to .env.local for overrides. .env gets committed; .env.local does not.


# Base URL of DevHub API. Leave blank in dev to use the Vite proxy (/api → localhost:8766).
# Set explicitly in preview/prod builds, e.g. http://devhub.lan:8766
VITE_API_URL=


# ── Azure AD / MSAL ──────────────────────────────────────────────────────
# Public SPA values — these ship in the bundle. Reuse the JobScan app
# registration (public client, Graph scopes, SPA redirect already wired
# to http://localhost:5174).
VITE_AAD_TENANT_ID=99857259-7d6a-47fb-a35b-7f6004c4965d
VITE_AAD_CLIENT_ID=79633382-952d-4e11-bd6d-6f047bf5732b
